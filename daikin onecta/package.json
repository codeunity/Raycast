{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "onecta",
  "type": "module",
  "title": "Onecta",
  "description": "Access, control and monitor your Daikin devices",
  "icon": "extension-icon.png",
  "author": "Michi-2124",
  "owner": "codeunity-gmbh",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "devices",
      "title": "Devices",
      "description": "Show all devices.",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "clientId",
      "title": "Client ID",
      "description": "Your daikin onecta client id.",
      "type": "textfield",
      "required": true
    },
    {
      "name": "clientSecret",
      "title": "Client Secret",
      "description": "Your daikin onecta client secret.",
      "type": "password",
      "required": true
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.100.3",
    "@raycast/utils": "^2.0.1",
    "es-toolkit": "^1.39.5",
    "luxon": "^3.6.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/luxon": "^3.6.2",
    "@types/node": "^22.15.33",
    "@types/node-fetch": "^2.6.12",
    "@types/react": "^19.1.8",
    "eslint": "^9.29.0",
    "prettier": "^3.6.0",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
